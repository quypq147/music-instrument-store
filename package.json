{
  "name": "music-instrument-store",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "packages/*",
    "services/*",
    "infrastructure"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:web": "npm run dev -w @music-store/web",
    "lint": "npm run lint --workspaces --if-present",
    "seed:products": "node scripts/import-products-to-dynamodb.mjs"
  }
}
